# ─────────────────────────────────────────────
#  Copy this to .env.local and fill in values.
#  NEVER commit .env.local to git.
# ─────────────────────────────────────────────

# Supabase — Project Settings → API → API Keys (new keys, not Legacy API Keys)
# Use a secret key (sb_secret_...) — server-side only; replaces JWT service_role
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SECRET_KEY=sb_secret_your-secret-key-here

# Publishable (anon) key — server proxy, session, and browser auth (dashboard).
SUPABASE_PUBLISHABLE_KEY=sb_publishable_your-publishable-key-here
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_your-publishable-key-here
# Signup email links: Supabase → Authentication → URL Configuration → Redirect URLs must include
# your dashboard origin + /login, e.g. http://dashboard.localhost:3000/login and https://dashboard.example.com/login

# Dashboard URL is fixed: always dashboard.<apex> (strip leading www.), same scheme/port as the request.
# Local dev: http://dashboard.localhost:3000 when the app is on localhost:3000.

# Host allowlist (optional each). If BOTH are empty, Host/Origin checks are disabled.
#
# ALLOWED_DOMAIN — one production apex (any format is normalized):
#   example.com, www.example.com, https://example.com/path — all become apex "example.com".
# Allows that host, www., every subdomain (e.g. dashboard.example.com), any port, http & https,
# and any path. Origin/Referer must also match the same hostname rules.
# ALLOWED_DOMAIN=example.com
#
# LOCAL_ALLOWED_HOST — one local hostname for dev (optional):
#   localhost — allows localhost, *.localhost (e.g. dashboard.localhost), 127.0.0.1, [::1], any port, http & https.
# LOCAL_ALLOWED_HOST=localhost

# Rate limiting (production only; requires rate_limit_events + fn_check_and_record_rate_limit in Supabase)
RATE_LIMIT_MAX=5             # max hits per route per IP per window (survey_post, survey_status)
RATE_LIMIT_WINDOW_MS=900000  # 15 minutes
RATE_LIMIT_STATUS_MAX=120    # /api/survey/status per IP per window

# SMS (Prelude) — each send counts: initial submit + resend. Per IP.
RATE_LIMIT_SMS_SEND_MAX=20
RATE_LIMIT_SMS_SEND_WINDOW_MS=86400000

# Resend endpoint only — /api/survey/resend per IP
RATE_LIMIT_RESEND_MAX=8
RATE_LIMIT_RESEND_WINDOW_MS=3600000

# Minimum seconds between SMS sends for the same registration (server + DB otp_last_sent_at)
OTP_RESEND_COOLDOWN_SEC=60

# Survey session: HttpOnly cookie survey_session (signed token). Default 365 days if unset.
SURVEY_TOKEN_MAX_AGE_MS=31536000000

# Prelude — Verify API (SMS OTP). Dashboard → All Services → Configure → Keys
# https://docs.prelude.so/verify/v2/documentation/quickstart
PRELUDE_API_TOKEN=your-prelude-api-token

# Meta Pixel — leave empty or remove to disable tracking.
# Get your Pixel ID from Meta Events Manager: https://business.facebook.com/events_manager
# NEXT_PUBLIC_META_PIXEL_ID=
